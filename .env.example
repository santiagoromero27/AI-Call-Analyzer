# Database — SQLite for local dev; swap in Postgres URL for prod
DATABASE_URL=sqlite:///./calls.db

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Telegram — leave blank to disable alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webhook security — must match X-Webhook-Secret header sent by Moja
WEBHOOK_SECRET=changeme

# Transcription
# WHISPER_MODEL options: tiny / base / small / medium / large-v3
WHISPER_MODEL=base
# Which stereo channel is the CALLER: 0=left, 1=right (confirm with a real recording in Phase 2)
CALLER_CHANNEL=0
